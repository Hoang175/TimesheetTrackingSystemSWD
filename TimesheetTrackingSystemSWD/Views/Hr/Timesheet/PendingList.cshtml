@model IEnumerable<TimesheetTrackingSystemSWD.DAL.Models.Timesheet>

@{
    ViewData["Title"] = "Timesheet Approval";
    Layout = "~/Views/Shared/_HrLayout.cshtml";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Timesheet Approval</h1>
</div>

<div class="bg-white shadow-md rounded-xl border border-gray-100 overflow-hidden">

    <!-- HEADER -->
    <div class="px-6 py-4 border-b bg-gray-50">
        <p class="text-sm text-gray-600">
            Danh sách các timesheet đang chờ phê duyệt
        </p>
    </div>

    <!-- TABLE -->
    <div class="overflow-x-auto">
        <table class="min-w-full text-sm text-left">
            <thead class="bg-gray-100 text-gray-700 uppercase text-xs">
                <tr>
                    <th class="px-6 py-3">ID</th>
                    <th class="px-6 py-3">Employee</th>
                    <th class="px-6 py-3">Period</th>
                    <th class="px-6 py-3">Hours</th>
                    <th class="px-6 py-3 text-center">Status</th>
                    <th class="px-6 py-3 text-center">Action</th>
                </tr>
            </thead>

            <tbody class="divide-y">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-10 text-gray-500">
                            Không có timesheet pending
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 font-medium text-gray-800">
                                #@item.TimesheetId
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 bg-blue-100 text-blue-600 flex items-center justify-center rounded-full font-semibold">
                                        @item.Employee?.EmployeeCode.Substring(0, 1)
                                    </div>
                                    <span>@item.Employee?.EmployeeCode</span>
                                </div>
                            </td>

                            <td class="px-6 py-4 text-gray-600">
                                @item.PeriodStart → @item.PeriodEnd
                            </td>

                            <td class="px-6 py-4 font-semibold text-gray-800">
                                @item.TotalWorkingHours h
                            </td>

                            <!-- STATUS BADGE -->
                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 text-xs rounded-full bg-yellow-100 text-yellow-700">
                                    Pending
                                </span>
                            </td>

                            <!-- ACTION -->
                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-2">

                                    <!-- APPROVE -->
                                    <a href="/TimesheetTrackingSystem/hr/approve/@item.TimesheetId"
                                       onclick="return confirm('Approve timesheet này?')"
                                       class="px-3 py-1.5 text-sm bg-green-500 text-white rounded-lg hover:bg-green-600 shadow-sm">
                                        ✔ Approve
                                    </a>

                                    <!-- REJECT -->
                                    <a href="/TimesheetTrackingSystem/hr/reject/@item.TimesheetId"
                                       onclick="return confirm('Reject timesheet này?')"
                                       class="px-3 py-1.5 text-sm bg-red-500 text-white rounded-lg hover:bg-red-600 shadow-sm">
                                        ✖ Reject
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>