@model IEnumerable<TimesheetTrackingSystemSWD.DAL.Models.Timesheet>

@{
    ViewData["Title"] = "Duyệt Timesheet";
    Layout = "~/Views/Shared/_HrLayout.cshtml";
}

<div class="px-8 py-6 bg-white border-b border-gray-100 shadow-sm flex items-center justify-between">
    <div>
        <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-gradient-to-tr from-emerald-500 to-teal-500 flex items-center justify-center text-white shadow-lg shadow-emerald-200">
                <i class="fa-solid fa-file-signature"></i>
            </span>
            Phê Duyệt Timesheet
        </h2>
        <p class="text-sm text-gray-500 mt-1 ml-14">Danh sách bảng chấm công của nhân viên đang chờ xử lý.</p>
    </div>
</div>

<div class="p-8 min-h-screen">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 text-gray-600 font-bold uppercase text-xs tracking-wider border-b border-gray-200">
                <tr>
                    <th class="px-6 py-4 text-center">ID</th>
                    <th class="px-6 py-4">Nhân viên</th>
                    <th class="px-6 py-4">Kỳ chấm công (Period)</th>
                    <th class="px-6 py-4 text-center">Tổng giờ làm</th>
                    <th class="px-6 py-4 text-center">Trạng thái</th>
                    <th class="px-6 py-4 text-right">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-16 text-gray-500">
                            <div class="flex flex-col items-center justify-center">
                                <div class="w-16 h-16 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center text-2xl mb-3">
                                    <i class="fa-solid fa-check-double"></i>
                                </div>
                                <h3 class="font-bold text-gray-700">Tuyệt vời!</h3>
                                <p>Không còn bảng chấm công nào đang chờ xử lý.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-emerald-50/30 transition-colors">
                            <td class="px-6 py-4 text-center font-mono font-bold text-gray-400">
                                #@item.TimesheetId
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 bg-emerald-100 text-emerald-700 flex items-center justify-center rounded-full font-bold shadow-sm">
                                        @(item.Employee?.EmployeeCode?.Substring(0, 1) ?? "U")
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-800">@item.Employee?.User?.FullName</p>
                                        <p class="text-xs text-gray-500 font-mono">@item.Employee?.EmployeeCode</p>
                                    </div>
                                </div>
                            </td>

                            <td class="px-6 py-4 text-gray-600 font-medium">
                                @item.PeriodStart.ToString("dd/MM/yyyy") <i class="fa-solid fa-arrow-right text-[10px] mx-2 text-gray-300"></i> @item.PeriodEnd.ToString("dd/MM/yyyy")
                            </td>

                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 bg-gray-100 border border-gray-200 rounded-lg font-bold text-gray-700">@item.TotalWorkingHours h</span>
                            </td>

                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-wide rounded-full bg-amber-100 text-amber-700 border border-amber-200">
                                    Pending
                                </span>
                            </td>

                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick="handleAction('/TimesheetTrackingSystem/hr/approve/@item.TimesheetId', 'Approve')" class="px-3 py-1.5 flex items-center gap-1.5 text-xs font-bold bg-emerald-50 text-emerald-600 border border-emerald-200 rounded-lg hover:bg-emerald-600 hover:text-white transition-all shadow-sm">
                                        <i class="fa-solid fa-check"></i> Duyệt
                                    </button>

                                    <button onclick="handleAction('/TimesheetTrackingSystem/hr/reject/@item.TimesheetId', 'Reject')" class="px-3 py-1.5 flex items-center gap-1.5 text-xs font-bold bg-red-50 text-red-600 border border-red-200 rounded-lg hover:bg-red-600 hover:text-white transition-all shadow-sm">
                                        <i class="fa-solid fa-xmark"></i> Từ chối
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function handleAction(url, actionType) {
            let title = actionType === 'Approve' ? 'Duyệt Timesheet?' : 'Từ chối Timesheet?';
            let text = actionType === 'Approve' ? 'Xác nhận phê duyệt bảng chấm công này hợp lệ.' : 'Bảng chấm công này sẽ bị trả lại cho nhân viên.';
            let btnColor = actionType === 'Approve' ? '#10b981' : '#ef4444';
            let btnText = actionType === 'Approve' ? 'Đồng ý Duyệt' : 'Xác nhận Từ chối';

            Swal.fire({
                title: title,
                text: text,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: btnColor,
                cancelButtonColor: '#6b7280',
                confirmButtonText: btnText,
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }
    </script>
}