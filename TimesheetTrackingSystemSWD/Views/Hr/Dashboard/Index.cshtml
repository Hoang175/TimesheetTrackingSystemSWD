@{
    ViewData["Title"] = "HR Dashboard";
    Layout = "~/Views/Shared/_HrLayout.cshtml";
}

<div class="max-w-7xl mx-auto animate-fade-in py-12 px-6">
    <div class="mb-12">
        <div class="flex items-center gap-3 text-emerald-500 font-black text-xs uppercase tracking-[0.4em] mb-4">
            <span class="w-12 h-1 bg-emerald-100 rounded-full"></span>
            HR Workspace
        </div>
        <h1 class="text-6xl font-black text-gray-900 tracking-tighter leading-none mb-6">Xin chào, <br /><span class="text-emerald-600">Phòng Nhân sự</span></h1>
        <p class="text-xl text-gray-400 font-bold max-w-2xl leading-relaxed">Theo dõi và quản lý toàn bộ quy trình phê duyệt bảng chấm công của nhân viên tại đây.</p>
    </div>

    @if (ViewBag.PendingCount > 0)
    {
        <div class="bg-amber-50 border-l-4 border-amber-500 p-6 rounded-2xl mb-10 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center text-xl font-bold">
                    <i class="fa-solid fa-bell"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-amber-800">Cần xử lý</h3>
                    <p class="text-amber-700 text-sm">Hệ thống đang có <b>@ViewBag.PendingCount</b> bảng chấm công đang chờ bạn phê duyệt.</p>
                </div>
            </div>
            <a href="/TimesheetTrackingSystem/hr/timesheets?status=Pending" class="px-5 py-2.5 bg-amber-500 text-white rounded-xl font-bold shadow-md hover:bg-amber-600 transition-colors">
                Xử lý ngay
            </a>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
        <div class="bg-white p-8 rounded-[30px] border-2 border-gray-100 shadow-sm relative overflow-hidden group hover:border-amber-200 transition-colors">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-amber-50 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-2 relative z-10">Chờ duyệt (Pending)</p>
            <h2 class="text-5xl font-black text-gray-800 relative z-10">@ViewBag.PendingCount</h2>
        </div>

        <div class="bg-white p-8 rounded-[30px] border-2 border-gray-100 shadow-sm relative overflow-hidden group hover:border-emerald-200 transition-colors">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-emerald-50 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-2 relative z-10">Đã duyệt (Approved)</p>
            <h2 class="text-5xl font-black text-gray-800 relative z-10">@ViewBag.ApprovedCount</h2>
        </div>

        <div class="bg-white p-8 rounded-[30px] border-2 border-gray-100 shadow-sm relative overflow-hidden group hover:border-red-200 transition-colors">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-red-50 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-2 relative z-10">Từ chối (Rejected)</p>
            <h2 class="text-5xl font-black text-gray-800 relative z-10">@ViewBag.RejectedCount</h2>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <a href="/TimesheetTrackingSystem/hr/timesheets?status=Pending"
           class="group bg-emerald-600 p-10 rounded-[40px] shadow-xl hover:bg-emerald-700 hover:scale-[1.02] transition-all duration-500 relative overflow-hidden block">

            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/10 rounded-full"></div>

            <div class="w-16 h-16 rounded-2xl bg-white/20 text-white flex items-center justify-center text-2xl mb-8 group-hover:rotate-12 transition-transform">
                <i class="fa-solid fa-file-signature"></i>
            </div>

            <h3 class="text-2xl font-black text-white mb-2 uppercase">
                Phê duyệt Timesheet
            </h3>

            <p class="text-emerald-100 font-medium">
                Kiểm tra và xử lý bảng chấm công của nhân viên gửi lên hệ thống.
            </p>
        </a>


        <a href="/TimesheetTrackingSystem/hr/logs" class="group bg-gray-900 p-10 rounded-[40px] shadow-xl hover:bg-gray-800 hover:scale-[1.02] transition-all duration-500 relative overflow-hidden block">
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/5 rounded-full"></div>
            <div class="w-16 h-16 rounded-2xl bg-white/10 text-white flex items-center justify-center text-2xl mb-8 group-hover:-rotate-12 transition-transform">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <h3 class="text-2xl font-black text-white mb-2 uppercase">Lịch sử (System Logs)</h3>
            <p class="text-gray-400 font-medium">Xem lại toàn bộ lịch sử thao tác Approve / Reject của bộ phận nhân sự.</p>
        </a>
    </div>
</div>

<style>
    @@keyframes fade-in {
        from { opacity: 0; transform: scale(0.95) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .animate-fade-in {
        animation: fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>