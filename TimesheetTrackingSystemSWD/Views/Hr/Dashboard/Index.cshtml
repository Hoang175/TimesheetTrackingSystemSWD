@{
    ViewData["Title"] = "HR Dashboard";
    Layout = "~/Views/Shared/_HrLayout.cshtml";
}

<div class="space-y-6">

    <!-- TITLE -->
    <div>
        <h1 class="text-2xl font-bold text-gray-800">
            👋 Xin chào bộ phận Nhân sự!
        </h1>
        <p class="text-gray-500 text-sm">
            Quản lý và phê duyệt bảng chấm công nhân viên
        </p>
    </div>

    <!-- ⚠️ ALERT nếu có pending -->
    @if (ViewBag.PendingCount > 0)
    {
        <div class="bg-yellow-50 border border-yellow-200 p-4 rounded-lg text-yellow-700">
            ⚠️ Có <b>@ViewBag.PendingCount</b> timesheet đang chờ duyệt!
        </div>
    }

    <!-- STATS -->
    <div class="grid grid-cols-3 gap-4">

        <div class="bg-yellow-50 p-5 rounded-xl border border-yellow-200 hover:shadow-md transition">
            <p class="text-sm text-yellow-700">Pending</p>
            <h2 class="text-3xl font-bold text-yellow-600">
                @ViewBag.PendingCount
            </h2>
        </div>

        <div class="bg-green-50 p-5 rounded-xl border border-green-200 hover:shadow-md transition">
            <p class="text-sm text-green-700">Approved</p>
            <h2 class="text-3xl font-bold text-green-600">
                @ViewBag.ApprovedCount
            </h2>
        </div>

        <div class="bg-red-50 p-5 rounded-xl border border-red-200 hover:shadow-md transition">
            <p class="text-sm text-red-700">Rejected</p>
            <h2 class="text-3xl font-bold text-red-600">
                @ViewBag.RejectedCount
            </h2>
        </div>

    </div>

    <!-- QUICK ACTION -->
    <div class="grid grid-cols-2 gap-4">

        <!-- APPROVAL CARD -->
        <div class="bg-blue-50 border border-blue-200 p-6 rounded-xl hover:shadow-md transition">
            <h3 class="text-lg font-semibold text-blue-800 mb-2">
                📋 Timesheet Approval
            </h3>

            <p class="text-sm text-blue-600 mb-4">
                Duyệt bảng chấm công của nhân viên nhanh chóng và chính xác.
            </p>

            <a href="/TimesheetTrackingSystem/hr/timesheets"
               class="inline-block px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                Đi đến duyệt →
            </a>
        </div>

        <!-- LOG CARD -->
        <div class="bg-gray-50 border p-6 rounded-xl hover:shadow-md transition">

            <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center gap-2">
                📝 System Logs
            </h3>

            <p class="text-sm text-gray-600 mb-4">
                Xem lịch sử duyệt Timesheet (Approve / Reject) của HR.
            </p>

            <!-- BUTTON -->
            <a href="/TimesheetTrackingSystem/hr/logs"
               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-800 transition">

                Xem log
                <span>→</span>
            </a>

        </div>

    </div>

</div>