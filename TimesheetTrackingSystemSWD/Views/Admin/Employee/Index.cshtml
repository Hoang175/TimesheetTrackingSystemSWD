@model IEnumerable<TimesheetTrackingSystemSWD.DAL.Models.Employee>

@{
    ViewData["Title"] = "Quản Lý Nhân Sự";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int pageSize = 10;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int stt = (currentPage - 1) * pageSize;

    string keyword = ViewBag.Keyword as string;
    int? deptId = ViewBag.DeptId as int?;
    string status = ViewBag.Status as string;
}

<div class="px-8 py-6 bg-white border-b border-gray-100 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
        <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-gradient-to-tr from-emerald-500 to-teal-500 flex items-center justify-center text-white shadow-lg shadow-emerald-200">
                <i class="fa-solid fa-id-card-clip"></i>
            </span>
            Hồ Sơ Nhân Sự
        </h2>
        <p class="text-sm text-gray-500 mt-1 ml-14">Quản lý thông tin và tài khoản nhân viên.</p>
    </div>

    <a href="/TimesheetTrackingSystem/admin/employees/create" class="group inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md hover:shadow-xl hover:-translate-y-0.5">
        <i class="fa-solid fa-user-plus transition-transform group-hover:rotate-12"></i> <span>Thêm nhân viên</span>
    </a>
</div>

<div class="px-8 py-5 bg-gray-50 border-b border-gray-200 sticky top-0 z-20">
    <div class="flex flex-col xl:flex-row gap-4 justify-between items-center">
        <form method="get" class="flex flex-wrap gap-3 items-center w-full xl:w-auto">
            <div class="relative group w-full sm:w-64">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-emerald-500 transition-colors"></i>
                <input name="keyword" value="@keyword" placeholder="Tìm tên, mã nhân viên..." class="w-full pl-10 pr-3 py-2.5 bg-white border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none shadow-sm transition-all" />
            </div>

            <div class="w-full sm:w-48">
                <select name="deptId" asp-items="@ViewBag.Departments" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none shadow-sm cursor-pointer">
                    <option value="">-- Phòng ban --</option>
                </select>
            </div>

            <div class="w-full sm:w-40">
                <select name="status" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none shadow-sm cursor-pointer">
                    <option value="">-- Trạng thái --</option>
                    <option value="Active" selected="@(status == "Active")">Đang làm việc</option>
                    <option value="Inactive" selected="@(status == "Inactive")">Đã nghỉ</option>
                    <option value="Deleted" selected="@(status == "Deleted")">Đã xóa (Ẩn)</option>
                </select>
            </div>

            <button type="submit" class="bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors">
                <i class="fa-solid fa-filter mr-1"></i> Lọc
            </button>
            <a href="/TimesheetTrackingSystem/admin/employees" class="bg-white hover:bg-gray-100 text-gray-600 border border-gray-300 px-3 py-2.5 rounded-xl text-sm transition-colors" title="Làm mới">
                <i class="fa-solid fa-rotate-right"></i>
            </a>
        </form>

        <div class="flex bg-white p-1 rounded-xl border border-gray-200 shadow-sm">
            <button id="btnGridView" onclick="switchView('grid')" class="px-4 py-1.5 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-emerald-600">
                <i class="fa-solid fa-border-all mr-1"></i> Grid
            </button>
            <button id="btnListView" onclick="switchView('list')" class="px-4 py-1.5 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-emerald-600">
                <i class="fa-solid fa-list mr-1"></i> List
            </button>
        </div>
    </div>
</div>

<div class="p-8 min-h-screen">
    @if (Model == null || !Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 bg-white rounded-3xl border border-dashed border-gray-300">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                <i class="fa-solid fa-folder-open text-3xl text-gray-300"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-600">Không tìm thấy dữ liệu</h3>
            @if (status == "Deleted")
            {
                <p class="text-sm text-gray-400 mt-2">Thùng rác hiện đang trống.</p>
            }
        </div>
    }
    else
    {
        <div id="gridViewContainer">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var item in Model)
                {
                    bool isActive = (item.EmploymentStatus == "Active");
                    string fullName = item.User?.FullName ?? "N/A";
                    string initials = !string.IsNullOrEmpty(fullName) && fullName != "N/A" ? fullName.Substring(0, 1).ToUpper() : "U";

                    <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative flex flex-col h-full @(item.IsDeleted == true ? "opacity-75" : "")">
                        <div class="absolute top-4 right-4">
                            @if (item.IsDeleted == true)
                            {
                                <span class="px-2 py-1 rounded text-[10px] font-bold bg-red-50 text-red-600 border border-red-100"><i class="fa-solid fa-trash-can mr-1"></i>Đã Xóa</span>
                            }
                            else if (isActive)
                            {
                                <span class="px-2 py-1 rounded text-[10px] font-bold bg-green-50 text-green-600 border border-green-100">Active</span>
                            }
                            else
                            {
                                <span class="px-2 py-1 rounded text-[10px] font-bold bg-gray-100 text-gray-500 border border-gray-200">Inactive</span>
                            }
                        </div>

                        <div class="flex flex-col items-center mb-4">
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br @(item.IsDeleted == true ? "from-gray-400 to-gray-500" : "from-teal-400 to-emerald-500") text-white flex items-center justify-center font-bold text-2xl shadow-md mb-3 relative">
                                @initials
                                @if (item.User?.Status == "Active" && item.IsDeleted == false)
                                {
                                    <div class="absolute bottom-0 right-0 w-6 h-6 bg-white rounded-full flex items-center justify-center shadow border border-gray-100 text-emerald-500 text-xs" title="Được cấp quyền đăng nhập"><i class="fa-solid fa-user-check"></i></div>
                                }
                            </div>
                            <h3 class="text-lg font-bold text-gray-800 text-center line-clamp-1">@fullName</h3>
                            <p class="text-xs text-emerald-600 font-bold uppercase tracking-wide mt-1">@(item.Position ?? "N/A")</p>
                            <span class="mt-2 px-2 py-1 bg-gray-50 border border-gray-100 rounded text-[10px] text-gray-500 font-mono font-bold">@item.EmployeeCode</span>
                        </div>

                        <div class="space-y-2 mb-6 text-sm text-gray-500 flex-grow border-t border-gray-100 pt-4">
                            <div class="flex items-center gap-3"><i class="fa-regular fa-building text-gray-400 w-4"></i> <span class="truncate">@(item.Department?.DepartmentName ?? "Chưa phân bổ")</span></div>
                            <div class="flex items-center gap-3"><i class="fa-regular fa-envelope text-gray-400 w-4"></i> <span class="truncate">@(item.User?.Email ?? "N/A")</span></div>
                            <div class="flex items-center gap-3"><i class="fa-regular fa-calendar-check text-gray-400 w-4"></i> <span>Vào làm: @(item.HireDate?.ToString("dd/MM/yyyy") ?? "N/A")</span></div>
                        </div>

                        <div class="grid grid-cols-2 gap-2 pt-4 border-t border-gray-100">
                            @if (item.IsDeleted == true)
                            {
                                <button onclick="confirmAction(@item.EmployeeId, 'Restore')" class="col-span-2 py-2 flex items-center justify-center rounded-lg bg-blue-50 text-blue-600 border border-blue-100 hover:bg-blue-600 hover:text-white transition-colors"><i class="fa-solid fa-rotate-left mr-2"></i> Khôi phục hồ sơ</button>
                                <form id="action-form-restore-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/restore/@item.EmployeeId" method="post" class="hidden"></form>
                            }
                            else
                            {
                                <a href="/TimesheetTrackingSystem/admin/employees/edit/@item.EmployeeId" class="py-2 flex items-center justify-center rounded-lg border border-gray-200 text-gray-600 hover:border-emerald-500 hover:text-emerald-600 transition-colors"><i class="fa-solid fa-pen mr-2"></i> Sửa</a>

                                @if (isActive)
                                {
                                    <button onclick="confirmAction(@item.EmployeeId, 'Inactive')" class="py-2 flex items-center justify-center rounded-lg border border-gray-200 text-orange-500 hover:bg-orange-50 hover:border-orange-200 transition-colors"><i class="fa-solid fa-user-slash mr-2"></i> Nghỉ việc</button>
                                    <form id="action-form-inactive-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/inactive/@item.EmployeeId" method="post" class="hidden"></form>
                                }
                                else
                                {
                                    <div class="flex gap-1">
                                        <button onclick="confirmAction(@item.EmployeeId, 'Active')" class="flex-1 py-2 flex items-center justify-center rounded-lg border border-emerald-200 text-emerald-600 hover:bg-emerald-50 transition-colors" title="Kích hoạt lại"><i class="fa-solid fa-check"></i></button>
                                        <form id="action-form-active-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/active/@item.EmployeeId" method="post" class="hidden"></form>

                                        <button onclick="confirmAction(@item.EmployeeId, 'Delete')" class="flex-1 py-2 flex items-center justify-center rounded-lg bg-red-50 text-red-600 border border-red-100 hover:bg-red-600 hover:text-white transition-colors" title="Xóa mềm vào thùng rác"><i class="fa-solid fa-trash"></i></button>
                                        <form id="action-form-delete-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/delete/@item.EmployeeId" method="post" class="hidden"></form>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="listViewContainer" class="hidden">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <table class="w-full text-sm text-left">
                    <thead class="bg-gray-50 text-gray-600 font-bold uppercase text-xs tracking-wider border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-4 text-center">STT</th>
                            <th class="px-6 py-4">Nhân viên</th>
                            <th class="px-6 py-4">Mã NV</th>
                            <th class="px-6 py-4">Chức vụ / Phòng ban</th>
                            <th class="px-6 py-4">Ngày vào làm</th>
                            <th class="px-6 py-4 text-center">Trạng thái</th>
                            <th class="px-6 py-4 text-right">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model)
                        {
                            bool isActive = (item.EmploymentStatus == "Active");
                            string fullName = item.User?.FullName ?? "N/A";

                            <tr class="hover:bg-emerald-50/30 transition-colors @(item.IsDeleted == true ? "bg-gray-50 opacity-75" : "")">
                                <td class="px-6 py-4 text-center text-gray-400 font-medium">@(++stt)</td>
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-700">@fullName</div>
                                    <div class="text-xs text-gray-400">@(item.User?.Email ?? "N/A")</div>
                                </td>
                                <td class="px-6 py-4"><span class="font-mono text-xs font-bold bg-gray-100 px-2 py-1 rounded text-gray-600">@item.EmployeeCode</span></td>
                                <td class="px-6 py-4">
                                    <div class="text-emerald-600 font-bold text-xs uppercase">@(item.Position ?? "N/A")</div>
                                    <div class="text-gray-500 text-xs mt-1">@(item.Department?.DepartmentName ?? "N/A")</div>
                                </td>
                                <td class="px-6 py-4">@(item.HireDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.IsDeleted == true)
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-700">Đã Xóa</span>
                                    }
                                    else if (isActive)
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700">Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-500">Inactive</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (item.IsDeleted == true)
                                        {
                                            <button onclick="confirmAction(@item.EmployeeId, 'Restore')" class="px-3 py-1.5 flex items-center justify-center rounded-lg bg-blue-50 border border-blue-200 text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm"><i class="fa-solid fa-rotate-left mr-1 text-xs"></i> Khôi phục</button>
                                            <form id="action-form-restore-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/restore/@item.EmployeeId" method="post" class="hidden"></form>
                                        }
                                        else
                                        {
                                            <a href="/TimesheetTrackingSystem/admin/employees/edit/@item.EmployeeId" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-emerald-600 hover:bg-emerald-600 hover:text-white transition-all shadow-sm" title="Sửa"><i class="fa-solid fa-pen text-xs"></i></a>
                                            @if (isActive)
                                            {
                                                <button onclick="confirmAction(@item.EmployeeId, 'Inactive')" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-orange-500 hover:bg-orange-500 hover:text-white transition-all shadow-sm" title="Nghỉ việc"><i class="fa-solid fa-user-slash text-xs"></i></button>
                                                <form id="action-form-inactive-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/inactive/@item.EmployeeId" method="post" class="hidden"></form>
                                            }
                                            else
                                            {
                                                <button onclick="confirmAction(@item.EmployeeId, 'Active')" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-emerald-600 hover:bg-emerald-600 hover:text-white transition-all shadow-sm" title="Kích hoạt lại"><i class="fa-solid fa-check text-xs"></i></button>
                                                <form id="action-form-active-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/active/@item.EmployeeId" method="post" class="hidden"></form>

                                                <button onclick="confirmAction(@item.EmployeeId, 'Delete')" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="Xóa mềm (Ẩn)"><i class="fa-solid fa-trash text-xs"></i></button>
                                                <form id="action-form-delete-@item.EmployeeId" action="/TimesheetTrackingSystem/admin/employees/delete/@item.EmployeeId" method="post" class="hidden"></form>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <div class="mt-8 flex justify-center pb-8">
                <nav class="inline-flex rounded-xl shadow-sm bg-white p-1.5 gap-1 border border-gray-200">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a href="?page=@i&keyword=@keyword&status=@status&deptId=@deptId"
                           class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold transition-all @(i == currentPage ? "bg-emerald-600 text-white shadow-md scale-105" : "text-gray-600 hover:bg-gray-100")">
                            @i
                        </a>
                    }
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const savedMode = localStorage.getItem('empViewMode') || 'grid';
            switchView(savedMode);

            let successMsg = '@TempData["Success"]';
            let errorMsg = '@TempData["Error"]';
            if (successMsg) Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: successMsg, showConfirmButton: false, timer: 3000 });
            if (errorMsg) Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: errorMsg, showConfirmButton: false, timer: 3000 });
        });

        function switchView(mode) {
            const listContainer = document.getElementById('listViewContainer');
            const gridContainer = document.getElementById('gridViewContainer');
            const btnList = document.getElementById('btnListView');
            const btnGrid = document.getElementById('btnGridView');

            if (mode === 'grid') {
                listContainer.classList.add('hidden');
                gridContainer.classList.remove('hidden');
                btnGrid.classList.add('bg-emerald-100', 'text-emerald-700');
                btnList.classList.remove('bg-emerald-100', 'text-emerald-700');
            } else {
                gridContainer.classList.add('hidden');
                listContainer.classList.remove('hidden');
                btnList.classList.add('bg-emerald-100', 'text-emerald-700');
                btnGrid.classList.remove('bg-emerald-100', 'text-emerald-700');
            }
            localStorage.setItem('empViewMode', mode);
        }

        // CẬP NHẬT HÀM JAVASCRIPT GỌI ACTION
        function confirmAction(id, actionType) {
            let title, text, btnColor, iconStyle;
            if (actionType === 'Inactive') {
                title = 'Nghỉ việc?';
                text = 'Nhân viên sẽ được chuyển sang trạng thái Đã nghỉ.';
                btnColor = '#f97316';
                iconStyle = 'warning';
            } else if (actionType === 'Delete') {
                title = 'Xóa mềm?';
                text = 'Hồ sơ này sẽ bị đưa vào Thùng rác.';
                btnColor = '#ef4444';
                iconStyle = 'warning';
            } else if (actionType === 'Active') {
                title = 'Kích hoạt lại?';
                text = 'Nhân viên sẽ được khôi phục trạng thái Đang làm việc.';
                btnColor = '#10b981';
                iconStyle = 'question';
            } else if (actionType === 'Restore') {
                title = 'Khôi phục?';
                text = 'Hồ sơ sẽ được khôi phục ra khỏi Thùng rác.';
                btnColor = '#3b82f6';
                iconStyle = 'info';
            }

            Swal.fire({
                title: title, text: text, icon: iconStyle, showCancelButton: true,
                confirmButtonColor: btnColor,
                confirmButtonText: 'Đồng ý', cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('action-form-' + actionType.toLowerCase() + '-' + id).submit();
                }
            });
        }
    </script>
}