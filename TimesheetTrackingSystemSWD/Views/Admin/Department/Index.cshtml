@model IEnumerable<TimesheetTrackingSystemSWD.BLL.DTOs.AdDepartment.AdDepartmentDTO>
@{
    ViewData["Title"] = "Quản Lý Phòng Ban";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string keyword = ViewBag.Keyword as string;
    string status = ViewBag.Status as string;
    bool isDeletedView = (status == "Deleted");
    string assignEmployeeKeyword = ViewBag.AssignEmployeeKeyword as string;
    int? assignDepartmentId = ViewBag.AssignDepartmentId as int?;
    bool openAssignModal = ViewBag.OpenAssignModal == true;
    var assignableEmployees = ViewBag.AssignableEmployees as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="px-8 py-6 bg-white border-b border-gray-100 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
        <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-gradient-to-tr from-emerald-500 to-teal-500 flex items-center justify-center text-white shadow-lg shadow-emerald-200">
                <i class="fa-solid fa-building-user"></i>
            </span>
            Quản Lý Phòng Ban
        </h2>
        <p class="text-sm text-gray-500 mt-1 ml-14">Thiết lập cơ cấu tổ chức và phòng ban của công ty.</p>
    </div>

    @if (!isDeletedView)
    {
        <button onclick="openCreateModal()" class="group inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md hover:shadow-xl hover:-translate-y-0.5">
            <i class="fa-solid fa-plus transition-transform group-hover:rotate-90"></i> <span>Thêm phòng ban</span>
        </button>
    }
</div>

<div class="px-8 py-5 bg-gray-50 border-b border-gray-200 sticky top-0 z-20">
    <form method="get" class="flex flex-wrap gap-3 items-center">
        <div class="relative group w-full sm:w-80">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-emerald-500 transition-colors"></i>
            <input name="keyword" value="@keyword" placeholder="Tìm tên phòng ban..." class="w-full pl-10 pr-3 py-2.5 bg-white border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none shadow-sm transition-all" />
        </div>

        <div class="w-full sm:w-48">
            <select name="status" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none shadow-sm cursor-pointer">
                <option value="Active" selected="@(status != "Deleted")">Đang hoạt động</option>
                <option value="Deleted" selected="@(status == "Deleted")">Đã xóa (Thùng rác)</option>
            </select>
        </div>

        <button type="submit" class="bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors">
            <i class="fa-solid fa-filter mr-1"></i> Lọc
        </button>
        <a href="/TimesheetTrackingSystem/admin/departments" class="bg-white hover:bg-gray-100 text-gray-600 border border-gray-300 px-4 py-2.5 rounded-xl text-sm transition-colors" title="Làm mới">
            <i class="fa-solid fa-rotate-right"></i>
        </a>
    </form>
</div>

<div class="p-8 min-h-screen">
    @if (Model == null || !Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 bg-white rounded-3xl border border-dashed border-gray-300">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                <i class="fa-solid fa-building-circle-xmark text-3xl text-gray-300"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-600">Không tìm thấy dữ liệu</h3>
            <p class="text-sm text-gray-400 mt-2">@(isDeletedView ? "Thùng rác hiện đang trống." : "Hãy nhấn 'Thêm phòng ban' để bắt đầu.")</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full @(isDeletedView ? "opacity-80" : "")">
                    <div class="flex items-start justify-between mb-4">
                        <div class="w-14 h-14 rounded-2xl @(isDeletedView ? "bg-red-50 text-red-600 border-red-100" : "bg-emerald-50 text-emerald-600 border-emerald-100") flex items-center justify-center text-2xl border shadow-sm">
                            <i class="fa-regular fa-building"></i>
                        </div>

                        <div class="flex gap-2">
                            @if (isDeletedView)
                            {
                                <button onclick="confirmRestore(@item.DepartmentId)" class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition-colors flex items-center justify-center border border-blue-200" title="Khôi phục">
                                    <i class="fa-solid fa-rotate-left text-xs"></i>
                                </button>
                                <form id="restore-form-@item.DepartmentId" action="/TimesheetTrackingSystem/admin/departments/restore/@item.DepartmentId" method="post" class="hidden">
                                    @Html.AntiForgeryToken()
                                </form>
                            }
                            else
                            {
                                <button onclick="openEditModal(@item.DepartmentId, '@Html.Raw(item.DepartmentName)', '@Html.Raw(item.Description ?? "")')" class="w-8 h-8 rounded-lg bg-gray-50 text-gray-500 hover:bg-emerald-50 hover:text-emerald-600 transition-colors flex items-center justify-center border border-gray-200" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen text-xs"></i>
                                </button>
                                <button onclick="confirmDelete(@item.DepartmentId, @item.EmployeeCount)" class="w-8 h-8 rounded-lg bg-gray-50 text-gray-500 hover:bg-red-50 hover:text-red-600 transition-colors flex items-center justify-center border border-gray-200" title="Xóa">
                                    <i class="fa-solid fa-trash text-xs"></i>
                                </button>
                                <form id="delete-form-@item.DepartmentId" action="/TimesheetTrackingSystem/admin/departments/delete/@item.DepartmentId" method="post" class="hidden">
                                    @Html.AntiForgeryToken()
                                </form>
                            }
                        </div>
                    </div>

                    <h3 class="text-lg font-bold text-gray-800 mb-2 line-clamp-1" title="@item.DepartmentName">@item.DepartmentName</h3>
                    <p class="text-sm text-gray-500 line-clamp-2 flex-grow mb-6">@(string.IsNullOrEmpty(item.Description) ? "Chưa có mô tả cho phòng ban này." : item.Description)</p>

                    @if (!isDeletedView)
                    {
                        <div class="pt-4 border-t border-gray-100 mt-auto space-y-2">
                            <button onclick="openAssignEmployeeModal(@item.DepartmentId, '@Html.Raw(item.DepartmentName)')" class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-100 text-blue-700 rounded-lg text-sm font-semibold transition-colors w-full justify-center group">
                                <i class="fa-solid fa-user-plus text-blue-500 group-hover:scale-110 transition-transform"></i>
                                <span>Thêm nhân viên</span>
                            </button>
                            <a href="/TimesheetTrackingSystem/admin/employees?deptId=@item.DepartmentId" class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 border border-emerald-100 text-emerald-700 rounded-lg text-sm font-semibold transition-colors w-full justify-center group">
                                <i class="fa-solid fa-users text-emerald-500 group-hover:scale-110 transition-transform"></i>
                                <span>@item.EmployeeCount nhân sự</span>
                                <i class="fa-solid fa-arrow-right text-xs ml-1 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<div id="assignEmployeeModal" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden animate__animated animate__fadeInUp animate__faster">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-user-plus text-blue-500 mr-2"></i>Thêm Nhân Viên</h3>
            <button onclick="closeAssignEmployeeModal()" class="text-gray-400 hover:text-red-500 transition-colors"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <form action="/TimesheetTrackingSystem/admin/departments/assign-employee" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" id="assignDepartmentId" name="departmentId" />

            <div class="space-y-4 mb-6">
                <div class="p-3 bg-blue-50 border border-blue-100 rounded-lg text-sm text-blue-800">
                    Phòng ban được chọn: <strong id="assignDepartmentName"></strong>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Nhân viên đang làm việc <span class="text-red-500">*</span></label>
                    <div class="mb-2">
                        <input id="employeeSearchInput"
                               type="text"
                               autocomplete="off"
                               value="@assignEmployeeKeyword"
                               placeholder="Nhập tên hoặc mã (vd: em, emp...)"
                               class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                    </div>
                    <input type="hidden" id="selectedEmployeeId" name="employeeId" required />
                    <div id="employeeSuggestions" class="mt-2 overflow-y-auto border border-gray-200 rounded-xl bg-white hidden" style="max-height: 220px;">
                        @foreach (var emp in assignableEmployees)
                        {
                            bool isDisabled = emp.IsSameDepartment;
                            <button type="button"
                                    class="employee-suggestion-item w-full text-left px-3 py-2 text-sm border-b border-gray-100 last:border-b-0 @(isDisabled ? "text-gray-400 bg-gray-50 cursor-not-allowed" : "text-gray-700 hover:bg-blue-50")"
                                    data-id="@emp.Id"
                                    data-text="@emp.DisplayText"
                                    data-disabled="@(isDisabled ? "true" : "false")">
                                <div class="flex items-center justify-between gap-2">
                                    <span>@emp.DisplayText</span>
                                    @if (isDisabled)
                                    {
                                        <span class="text-[10px] text-orange-600 font-semibold">Đã ở phòng này</span>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Gõ để tìm nhanh, chọn trực tiếp từ danh sách gợi ý bên dưới.</p>
                </div>
            </div>

            <div class="flex justify-end gap-3 border-t border-gray-100 pt-4">
                <button type="button" onclick="closeAssignEmployeeModal()" class="px-5 py-2.5 rounded-xl bg-white border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-all">Huỷ bỏ</button>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white font-bold shadow-md hover:bg-blue-700 transition-all">Thêm vào phòng ban</button>
            </div>
        </form>
    </div>
</div>

<div id="createModal" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden animate__animated animate__fadeInUp animate__faster">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-building-user text-emerald-500 mr-2"></i>Thêm Phòng Ban</h3>
            <button onclick="closeCreateModal()" class="text-gray-400 hover:text-red-500 transition-colors"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <form action="/TimesheetTrackingSystem/admin/departments/create" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Tên phòng ban <span class="text-red-500">*</span></label>
                    <input name="DepartmentName" type="text" required maxlength="100" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all font-bold text-gray-700" placeholder="VD: Phòng IT, Hành chính..." />
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Mô tả chi tiết</label>
                    <textarea name="Description" rows="3" maxlength="255" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-gray-700" placeholder="Chức năng, nhiệm vụ của phòng ban..."></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 border-t border-gray-100 pt-4">
                <button type="button" onclick="closeCreateModal()" class="px-5 py-2.5 rounded-xl bg-white border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-all">Huỷ bỏ</button>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-emerald-600 text-white font-bold shadow-md hover:bg-emerald-700 transition-all">Tạo mới</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden animate__animated animate__fadeInUp animate__faster">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-pen-to-square text-emerald-500 mr-2"></i>Cập Nhật Phòng Ban</h3>
            <button onclick="closeEditModal()" class="text-gray-400 hover:text-red-500 transition-colors"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <form id="editForm" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Tên phòng ban <span class="text-red-500">*</span></label>
                    <input id="editName" name="DepartmentName" type="text" required maxlength="100" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all font-bold text-gray-700" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Mô tả chi tiết</label>
                    <textarea id="editDesc" name="Description" rows="3" maxlength="255" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-gray-700"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 border-t border-gray-100 pt-4">
                <button type="button" onclick="closeEditModal()" class="px-5 py-2.5 rounded-xl bg-white border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-all">Huỷ bỏ</button>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-emerald-600 text-white font-bold shadow-md hover:bg-emerald-700 transition-all">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let successMsg = '@TempData["Success"]';
            let errorMsg = '@TempData["Error"]';
            if (successMsg) Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: successMsg, showConfirmButton: false, timer: 3000 });
            if (errorMsg) Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: errorMsg, showConfirmButton: false, timer: 3000 });

            setupEmployeeAutocomplete();
            if (@(openAssignModal.ToString().ToLower())) {
                const deptId = '@(assignDepartmentId?.ToString() ?? "")';
                if (deptId) {
                    openAssignEmployeeModal(deptId, 'Phòng ban đã chọn');
                    document.getElementById('employeeSuggestions').classList.remove('hidden');
                }
            }
        });

        function openCreateModal() { document.getElementById('createModal').classList.remove('hidden'); }
        function closeCreateModal() { document.getElementById('createModal').classList.add('hidden'); }
        function openAssignEmployeeModal(departmentId, departmentName) {
            document.getElementById('assignDepartmentId').value = departmentId;
            document.getElementById('assignDepartmentName').innerText = departmentName;
            document.getElementById('assignEmployeeModal').classList.remove('hidden');

            const searchInput = document.getElementById('employeeSearchInput');
            if (searchInput) {
                searchInput.value = '';
                document.getElementById('selectedEmployeeId').value = '';
                const suggestions = document.getElementById('employeeSuggestions');
                if (suggestions) {
                    suggestions.querySelectorAll('.employee-suggestion-item').forEach(item => item.classList.remove('hidden'));
                    suggestions.classList.remove('hidden');
                }
                setTimeout(() => searchInput.focus(), 0);
            }
        }
        function closeAssignEmployeeModal() {
            document.getElementById('assignEmployeeModal').classList.add('hidden');
            document.getElementById('employeeSuggestions').classList.add('hidden');
        }

        function setupEmployeeAutocomplete() {
            const searchInput = document.getElementById('employeeSearchInput');
            const selectedEmployeeId = document.getElementById('selectedEmployeeId');
            const suggestions = document.getElementById('employeeSuggestions');
            const form = document.querySelector('#assignEmployeeModal form');
            if (!searchInput || !selectedEmployeeId || !suggestions || !form) return;

            function bindSuggestionClicks() {
                suggestions.querySelectorAll('.employee-suggestion-item').forEach(item => {
                    item.addEventListener('click', function () {
                        if (this.dataset.disabled === 'true') return;
                        searchInput.value = this.dataset.text || '';
                        selectedEmployeeId.value = this.dataset.id || '';
                        suggestions.classList.add('hidden');
                    });
                });
            }
            bindSuggestionClicks();

            searchInput.addEventListener('input', function () {
                selectedEmployeeId.value = '';
                const keyword = (this.value || '').toLowerCase().trim();
                let visible = 0;
                suggestions.querySelectorAll('.employee-suggestion-item').forEach(item => {
                    const text = (item.dataset.text || '').toLowerCase();
                    const show = keyword.length === 0 || text.includes(keyword);
                    item.classList.toggle('hidden', !show);
                    if (show) visible++;
                });
                suggestions.classList.toggle('hidden', visible === 0);
            });

            searchInput.addEventListener('focus', function () {
                suggestions.classList.remove('hidden');
            });

            document.addEventListener('click', function (event) {
                if (!document.getElementById('assignEmployeeModal').contains(event.target)) return;
                if (event.target === searchInput || suggestions.contains(event.target)) return;
                suggestions.classList.add('hidden');
            });

            form.addEventListener('submit', function (event) {
                if (!selectedEmployeeId.value) {
                    event.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Chưa chọn nhân viên',
                        text: 'Hãy chọn một nhân viên từ danh sách gợi ý trước khi thêm.'
                    });
                }
            });
        }

        function openEditModal(id, name, desc) {
            document.getElementById('editName').value = name;
            document.getElementById('editDesc').value = desc;
            document.getElementById('editForm').action = '/TimesheetTrackingSystem/admin/departments/edit/' + id;
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }

        function confirmDelete(id, employeeCount) {
            if (employeeCount > 0) {
                Swal.fire({
                    title: 'Không thể xóa!',
                    text: `Phòng ban này đang có ${employeeCount} nhân sự. Hãy thuyên chuyển họ sang phòng ban khác trước khi xóa.`,
                    icon: 'error',
                    confirmButtonColor: '#10b981',
                    confirmButtonText: 'Đã hiểu'
                });
                return;
            }

            Swal.fire({
                title: 'Xác nhận xóa?',
                text: 'Bạn có chắc chắn muốn ẩn phòng ban này khỏi hệ thống?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + id).submit();
                }
            });
        }

        // Script cho nút Khôi phục
        function confirmRestore(id) {
            Swal.fire({
                title: 'Khôi phục phòng ban?',
                text: 'Phòng ban này sẽ hoạt động trở lại.',
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Khôi phục',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('restore-form-' + id).submit();
                }
            });
        }
    </script>
}