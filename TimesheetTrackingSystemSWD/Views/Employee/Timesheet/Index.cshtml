@model TimesheetTrackingSystemSWD.BLL.DTOs.TimesheetSubmissionDTO
@{
    ViewData["Title"] = "Bảng công của tôi";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in font-sans">
    <!-- Header Section -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 text-emerald-600 font-black text-xs uppercase tracking-[0.3em] mb-3">
                <span class="w-10 h-1 bg-emerald-100 rounded-full"></span>
                Report Module
            </div>
            <h1 class="text-4xl font-black text-gray-900 tracking-tighter uppercase">Timesheet Submission</h1>
            <p class="mt-2 text-gray-400 font-bold">Quản lý và thống kê thời gian làm việc hàng tuần/tháng.</p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
            <div class="px-5 py-3 rounded-2xl bg-white border-2 border-emerald-100 shadow-xl flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center text-xs">
                    <i class="fa-solid fa-calendar-days"></i>
                </div>
                <span class="text-sm font-black text-emerald-900 opacity-60">Kỳ: @Model.PeriodStart.ToString("dd/MM") - @Model.PeriodEnd.ToString("dd/MM")</span>
            </div>
            <div class="px-5 py-3 rounded-2xl bg-emerald-600 text-white shadow-emerald-200 shadow-xl border-b-4 border-emerald-800 flex items-center gap-3">
                <i class="fa-solid fa-layer-group"></i>
                <span class="text-sm font-black uppercase">@Model.PeriodType</span>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-8 border-l-8 border-emerald-500 bg-white p-6 rounded-3xl shadow-xl flex items-center animate-bounce-subtle">
            <i class="fa-solid fa-circle-check text-emerald-500 text-3xl mr-4"></i>
            <p class="text-md font-black text-emerald-900">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-8 border-l-8 border-amber-400 bg-white p-6 rounded-3xl shadow-xl flex items-center">
            <i class="fa-solid fa-circle-exclamation text-amber-500 text-3xl mr-4"></i>
            <p class="text-md font-black text-amber-900">@TempData["ErrorMessage"]</p>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Summary Cards column -->
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100 transition-all hover:shadow-emerald-100 p-8">
                <h3 class="text-gray-900 font-black text-xl flex items-center gap-3 mb-10">
                    <i class="fa-solid fa-chart-line text-emerald-500"></i>
                    Thống kê kỳ này
                </h3>

                <div class="relative group">
                    <div class="absolute -inset-2 bg-gradient-to-r from-emerald-400 to-teal-500 rounded-[40px] opacity-20 blur group-hover:opacity-40 transition-opacity"></div>
                    <div class="relative flex flex-col items-center justify-center p-12 bg-white rounded-[40px] border-4 border-emerald-50 mb-10">
                        <span class="text-7xl font-black text-emerald-600 tracking-tighter">@Model.TotalWorkingHours</span>
                        <span class="mt-2 text-[10px] font-black text-gray-300 uppercase tracking-widest text-center">TỔNG GIỜ CÔNG</span>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex justify-between items-center bg-emerald-50/50 p-5 rounded-3xl border-2 border-transparent hover:border-emerald-100 transition-all">
                        <span class="text-xs font-black text-emerald-300 uppercase">Số ngày làm</span>
                        <span class="text-lg font-black text-emerald-900">@Model.AttendanceRecords.Count <span class="text-xs opacity-40 font-bold ml-1">NGÀY</span></span>
                    </div>
                    <div class="flex justify-between items-center bg-emerald-50/50 p-5 rounded-3xl border-2 border-transparent hover:border-emerald-100 transition-all">
                        <span class="text-xs font-black text-emerald-300 uppercase">Dữ liệu</span>
                        @if (Model.AttendanceRecords.All(a => a.IsComplete))
                        {
                            <span class="text-[10px] font-black px-4 py-2 bg-emerald-500 text-white rounded-full shadow-emerald-100 shadow-md">HOÀN TẤT</span>
                        }
                        else
                        {
                            <span class="text-[10px] font-black px-4 py-2 bg-amber-400 text-white rounded-full shadow-amber-100 shadow-md">CÒN THIẾU</span>
                        }
                    </div>
                </div>

                <div class="mt-12">
                    @if (Model.CanSubmit)
                    {
                        <form asp-action="Submit" method="post">
                            <input type="hidden" name="periodStart" value="@Model.PeriodStart.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="periodEnd" value="@Model.PeriodEnd.ToString("yyyy-MM-dd")" />
                            <button type="submit" class="w-full py-6 px-8 bg-emerald-600 hover:bg-emerald-700 text-white font-black rounded-3xl shadow-emerald-200 shadow-xl border-b-8 border-emerald-900 transition-all active:border-b-0 active:translate-y-2 flex items-center justify-center gap-3 text-lg">
                                <i class="fa-solid fa-paper-plane"></i>
                                SUBMIT NOW
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="p-6 bg-gray-50 rounded-3xl border-4 border-dotted border-gray-200 text-gray-400 flex flex-col items-center gap-6">
                            <button disabled class="w-full py-6 px-8 bg-gray-200 text-gray-400 font-black rounded-3xl cursor-not-allowed flex items-center justify-center gap-2">
                                <i class="fa-solid fa-lock"></i>
                                SUBMIT SYSTEM
                            </button>
                            <div class="flex items-start gap-4 px-2">
                                <i class="fa-solid fa-triangle-exclamation text-amber-400 text-xl font-black"></i>
                                <p class="text-[11px] font-black text-gray-400 leading-relaxed uppercase tracking-tight">
                                    @Model.ValidationMessage
                                </p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-gray-900 rounded-[40px] p-8 text-white shadow-2xl shadow-gray-200">
                <h4 class="text-emerald-400 font-black flex items-center gap-3 mb-6 uppercase text-sm tracking-widest">
                    <i class="fa-solid fa-circle-info"></i>
                    Rules & Guidelines
                </h4>
                <div class="space-y-6">
                    <div class="flex gap-4">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></div>
                        <p class="text-xs font-bold text-gray-400 leading-6">Nộp công vào <span class="text-white">Thứ 6, 7 hoặc Chủ Nhật</span> hàng tuần.</p>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></div>
                        <p class="text-xs font-bold text-gray-400 leading-6">Đảm bảo tất cả ca làm việc đã được <span class="text-white">Check-out</span> đầy đủ.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attendance Table Section -->
        <div class="lg:col-span-8">
            <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100 flex flex-col h-full">
                <div class="p-8 border-b-2 border-emerald-50 flex items-center justify-between bg-emerald-50/20">
                    <h3 class="text-xl font-black text-gray-900 tracking-tighter uppercase">Detailed Shifts</h3>
                    <div class="px-4 py-2 bg-white rounded-2xl border-2 border-emerald-100 text-[10px] font-black text-emerald-600 flex items-center gap-2">
                        <span class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></span>
                        LIVE DATA
                    </div>
                </div>
                
                <div class="flex-1 overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white text-emerald-400 text-[10px] font-black uppercase tracking-[0.2em] border-b border-gray-50">
                                <th class="px-8 py-6">Date</th>
                                <th class="px-8 py-6">Check-in</th>
                                <th class="px-8 py-6">Check-out</th>
                                <th class="px-8 py-6">Summary</th>
                                <th class="px-8 py-6 text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @foreach (var record in Model.AttendanceRecords)
                            {
                                <tr class="hover:bg-emerald-50/30 transition-all duration-300 group">
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-sm font-black text-gray-800">@record.WorkDate.ToString("dd/MM/yyyy")</span>
                                            <span class="text-[10px] text-emerald-400 font-black uppercase">@record.WorkDate.ToString("dddd")</span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6 text-sm font-bold text-gray-500">
                                        @(record.CheckInTime?.ToString("HH:mm") ?? "--:--")
                                    </td>
                                    <td class="px-8 py-6 text-sm font-bold text-gray-500">
                                        @(record.CheckOutTime?.ToString("HH:mm") ?? "--:--")
                                    </td>
                                    <td class="px-8 py-6">
                                        @if (record.DailyHours.HasValue)
                                        {
                                            <div class="inline-flex items-center px-4 py-2 rounded-2xl text-xs font-black bg-emerald-600 text-white shadow-lg shadow-emerald-100">
                                                @record.DailyHours.Value.ToString("F2") H
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-200 text-xs font-black">0.00 H</span>
                                        }
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        @if (record.IsComplete)
                                        {
                                            <div class="flex justify-center">
                                                <div class="w-10 h-10 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center border-2 border-emerald-100 shadow-sm">
                                                    <i class="fa-solid fa-check"></i>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex justify-center">
                                                <div class="w-10 h-10 rounded-2xl bg-amber-50 text-amber-500 flex items-center justify-center border-2 border-amber-100 shadow-sm">
                                                    <i class="fa-solid fa-clock animate-pulse"></i>
                                                </div>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in {
        from { opacity: 0; transform: scale(0.98) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .animate-fade-in {
        animation: fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @@keyframes bounce-subtle {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }
    .animate-bounce-subtle {
        animation: bounce-subtle 3s infinite ease-in-out;
    }
</style>
