@using TimesheetTrackingSystemSWD.BLL.DTOs
@using TimesheetTrackingSystemSWD.BLL.Helpers
@inject IHttpContextAccessor HttpContextAccessor

@{
    var user = HttpContextAccessor.HttpContext?.Session.GetObject<UserSessionDTO>("USER_SESSION");
    var fullName = user?.FullName ?? "Admin";
    var roleName = user?.RoleName ?? "N/A";
    var firstLetter = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "A";

    var path = HttpContextAccessor.HttpContext?.Request.Path.Value?.ToLower() ?? "";
    string IsActive(string checkPath) => path.Contains(checkPath) ? "active bg-emerald-100 text-emerald-700" : "text-gray-600 hover:bg-gray-50 hover:text-emerald-600";
}

<aside class="w-64 bg-white border-r border-gray-200 flex-shrink-0 h-screen sticky top-0 font-sans z-30 hidden lg:flex flex-col shadow-sm">
    <div class="h-16 flex items-center px-6 border-b border-gray-100">
        <div class="flex items-center gap-3 text-emerald-700 font-bold text-xl">
            <i class="fa-regular fa-clock"></i>
            <span>Timesheet</span>
        </div>
    </div>

    <div class="p-5 border-b border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-emerald-600 text-white flex items-center justify-center font-bold shadow-sm">
                @firstLetter
            </div>
            <div class="overflow-hidden">
                <p class="font-bold text-gray-800 text-sm truncate">@fullName</p>
                <p class="text-xs text-gray-500 font-medium">@roleName</p>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
        <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-4">Tổng quan</p>
        <a href="/TimesheetTrackingSystem/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors @IsActive("/admin")">
            <i class="fa-solid fa-chart-pie w-5 text-center"></i>
            <span>Dashboard</span>
        </a>

        <p class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-6">Quản trị</p>
        <a href="/TimesheetTrackingSystem/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors @IsActive("/admin/users")">
            <i class="fa-solid fa-users-gear w-5 text-center"></i>
            <span>Quản lý Tài khoản</span>
        </a>
        <a href="/TimesheetTrackingSystem/admin/employees" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors @IsActive("/admin/employees")">
            <i class="fa-solid fa-id-card-clip w-5 text-center"></i>
            <span>Quản lý Nhân viên</span>
        </a>
    </nav>

    <div class="p-4 border-t border-gray-100 bg-gray-50/50">
        <a href="/TimesheetTrackingSystem/logout" class="flex items-center justify-center gap-2 w-full py-2 px-4 rounded-lg text-sm font-semibold text-red-600 bg-red-50 hover:bg-red-100 transition-colors">
            <i class="fa-solid fa-arrow-right-from-bracket"></i>
            <span>Đăng xuất</span>
        </a>
    </div>
</aside>