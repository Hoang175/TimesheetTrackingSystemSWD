@using TimesheetTrackingSystemSWD.BLL.DTOs
@using TimesheetTrackingSystemSWD.BLL.Helpers
@inject IHttpContextAccessor HttpContextAccessor

@{
    var user = HttpContextAccessor.HttpContext?.Session.GetObject<UserSessionDTO>("USER_SESSION");
    var fullName = user?.FullName ?? "Employee";
    var roleName = user?.RoleName ?? "Employee";
    var firstLetter = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "E";

    var path = HttpContextAccessor.HttpContext?.Request.Path.Value?.ToLower() ?? "";
    string IsActive(string checkPath) => path.EndsWith(checkPath) || (checkPath != "/employee" && path.Contains(checkPath)) 
        ? "active bg-emerald-100 text-emerald-700 shadow-sm border border-emerald-200" 
        : "text-gray-600 hover:bg-emerald-50 hover:text-emerald-600";
}

<aside class="w-64 bg-white border-r border-gray-200 flex-shrink-0 h-screen sticky top-0 font-sans z-30 hidden lg:flex flex-col shadow-sm">
    <div class="h-16 flex items-center px-6 border-b border-gray-100 bg-emerald-50/30">
        <div class="flex items-center gap-3 text-emerald-700 font-bold text-xl">
            <i class="fa-solid fa-leaf"></i>
            <span>Time Sheet</span>
        </div>
    </div>

    <div class="p-5 border-b border-gray-100 bg-white">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 text-white flex items-center justify-center font-bold shadow-lg transform rotate-3">
                @firstLetter
            </div>
            <div class="overflow-hidden">
                <p class="font-bold text-gray-800 text-sm truncate uppercase tracking-tighter">@fullName</p>
                <p class="text-xs text-emerald-600 font-bold">@roleName</p>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
        <p class="px-2 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Operations</p>
        
        <a href="/TimesheetTrackingSystem/employee" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all duration-200 @IsActive("/employee")">
            <i class="fa-solid fa-house-chimney w-5 text-center"></i>
            <span>Trang chủ</span>
        </a>

        <a href="/TimesheetTrackingSystem/employee/attendance" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all duration-200 @IsActive("/employee/attendance")">
            <i class="fa-solid fa-clock w-5 text-center"></i>
            <span>Check-in / Out</span>
        </a>

        <a href="/TimesheetTrackingSystem/employee/mytimesheet" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all duration-200 @IsActive("/employee/mytimesheet")">
            <i class="fa-solid fa-calendar-check w-5 text-center"></i>
            <span>Bảng công của tôi</span>
        </a>
    </nav>

    <div class="p-4 border-t border-gray-100 bg-emerald-50/50">
        <a href="/TimesheetTrackingSystem/logout" class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-700 shadow-md transition-all active:scale-95">
            <i class="fa-solid fa-power-off"></i>
            <span>Đăng xuất</span>
        </a>
    </div>
</aside>